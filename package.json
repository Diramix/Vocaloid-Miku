{
	"name": "vocaloid-miku",
	"license": "CC0-1.0",
	"scripts": {
		"dev": "ymtm dev",
		"build": "ymtm build",
		"build:nextmusic": "ymtm build nextmusic",
		"build:pulsesync": "ymtm build pulsesync",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"build": {
		"package": [
			"nextmusic",
			"pulsesync"
		]
	},
	"nextmusic": {
		"tarGz": {
			"artifactName": "Vocaloid-Miku_${theme.version}_${build.package}.tar.gz"
		}
	},
	"pulsesync": {
		"zip": {
			"artifactName": "Vocaloid-Miku_${theme.version}_${build.package}.zip"
		},
		"pext": {
			"artifactName": "Vocaloid-Miku_${theme.version}_${build.package}.pext"
		}
	},
	"devDependencies": {
		"@diram1x/ymtm": "^3.2.0",
		"prettier": "^3.8.3"
	}
}
